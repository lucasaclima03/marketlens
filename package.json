{
  "name": "marketlens",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-source price intelligence aggregator for retail prices in Brazil.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22 <23"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "start:dev:api": "tsx watch src/main-api.ts",
    "start:dev:worker": "tsx watch src/main-worker.ts",
    "start:api": "node dist/main-api.js",
    "start:worker": "node dist/main-worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli/main.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nestjs/testing": "^11.1.19",
    "@testcontainers/postgresql": "^10.28.0",
    "@testcontainers/redis": "^10.28.0",
    "@types/node": "^22.19.18",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.27.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-sonarjs": "^2.0.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "5.6",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@bull-board/api": "^6.21.3",
    "@bull-board/express": "^6.21.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/terminus": "^11.1.1",
    "axios": "^1.16.0",
    "bullmq": "^5.76.7",
    "drizzle-orm": "^0.34.1",
    "nest-commander": "^3.20.1",
    "nestjs-pino": "^4.6.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  }
}
